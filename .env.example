# ── App ──────────────────────────────────────
APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
# 可选：默认仅 localhost/.local 显示“本地登录”入口；
# 若你在自托管域名也需要显示本地登录，可显式设为 true
NEXT_PUBLIC_ENABLE_LOCAL_LOGIN=false

# ── Auth / Security ──────────────────────────
JWT_SECRET=replace-with-strong-secret
BYOK_ENCRYPTION_KEY=replace-with-32bytes-secret
# required | self_host_no_login
AUTH_MODE=self_host_no_login
SELF_HOST_EMAIL=selfhost@draftorbit.local
SELF_HOST_DISPLAY_NAME=Self-host Admin
SELF_HOST_WORKSPACE_SLUG=self-host
SELF_HOST_WORKSPACE_NAME=Self-host Workspace

# ── Database / Redis ─────────────────────────
DATABASE_URL=postgresql://draftorbit:draftorbit@localhost:5433/draftorbit
REDIS_URL=redis://localhost:6379

# ── X / Twitter OAuth ────────────────────────
X_CLIENT_ID=your-x-client-id
X_CLIENT_SECRET=your-x-client-secret
# 推荐设置为 Web 回调页，再由前端回调 API
X_CALLBACK_URL=http://localhost:3000/auth/callback
# 多账号绑定回调（可与 X_CALLBACK_URL 同域）
X_BIND_CALLBACK_URL=http://localhost:3000/x-accounts/oauth/callback

# ── Google OAuth（阶段 B 骨架）──────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google-callback

# ── 平台内容生成通道（内部使用）─────────────────
# 未配置时会走 mock 文本兜底
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key
# 可选：模型路由（逗号分隔）
OPENROUTER_FREE_MODELS=google/gemma-3-27b-it:free,deepseek/deepseek-chat-v3-0324:free,qwen/qwen3-32b:free
OPENROUTER_FLOOR_MODELS=deepseek/deepseek-chat,qwen/qwen3-32b,meta-llama/llama-3.3-70b-instruct
OPENROUTER_HIGH_MODELS=openai/gpt-4.1-mini,anthropic/claude-3.5-sonnet

# ── Stripe（可选）─────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Starter / Growth / Max（月付 + 年付，USD）
STRIPE_STARTER_MONTHLY_PRICE_ID=
STRIPE_STARTER_YEARLY_PRICE_ID=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_YEARLY_PRICE_ID=
STRIPE_PREMIUM_MONTHLY_PRICE_ID=
STRIPE_PREMIUM_YEARLY_PRICE_ID=
# 试用天数（默认 3；上线真实扣款验收可临时设为 0）
BILLING_TRIAL_DAYS=3
# 退款演练接口（默认关闭；仅测试窗口临时开启）
BILLING_SELF_SERVICE_REFUND_ENABLED=false
# 前端是否显示“退款演练”按钮（默认关闭）
NEXT_PUBLIC_BILLING_REFUND_DRILL_ENABLED=false
# 生产默认 false；仅在自托管/应急时允许 PayPal 回退
BILLING_PAYPAL_FALLBACK_ENABLED=false

# ── PayPal（可选，订阅 Webhook）───────────────
# Sandbox: https://api-m.sandbox.paypal.com
# Live:    https://api-m.paypal.com
PAYPAL_API_BASE=https://api-m.sandbox.paypal.com
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
# 可选：用于按 plan_id 映射 DraftOrbit 套餐
PAYPAL_PLAN_ID_STARTER=
PAYPAL_PLAN_ID_PRO=
PAYPAL_PLAN_ID_PREMIUM=
