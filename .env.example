# ── App ──────────────────────────────────────
APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
# 可选：默认仅 localhost/.local 显示“本地登录”入口；
# 若你在自托管域名也需要显示本地登录，可显式设为 true
NEXT_PUBLIC_ENABLE_LOCAL_LOGIN=false

# ── Auth / Security ──────────────────────────
JWT_SECRET=replace-with-strong-secret
BYOK_ENCRYPTION_KEY=replace-with-32bytes-secret
# required | self_host_no_login
AUTH_MODE=self_host_no_login
SELF_HOST_EMAIL=selfhost@draftorbit.local
SELF_HOST_DISPLAY_NAME=Self-host Admin
SELF_HOST_WORKSPACE_SLUG=self-host
SELF_HOST_WORKSPACE_NAME=Self-host Workspace

# ── Database / Redis ─────────────────────────
DATABASE_URL=postgresql://draftorbit:draftorbit@localhost:5433/draftorbit
REDIS_URL=redis://localhost:6379

# ── X / Twitter OAuth ────────────────────────
X_CLIENT_ID=your-x-client-id
X_CLIENT_SECRET=your-x-client-secret
# 推荐设置为 Web 回调页，再由前端回调 API
X_CALLBACK_URL=http://localhost:3000/auth/callback
# 多账号绑定回调（可与 X_CALLBACK_URL 同域）
X_BIND_CALLBACK_URL=http://localhost:3000/x-accounts/oauth/callback

# ── Google OAuth（阶段 B 骨架）──────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google-callback

# ── 平台内容生成通道（内部使用）─────────────────
# OpenAI 走官方 API key；Codex OAuth 仅允许本机可选 adapter，不能当线上 API key 替代。
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_TEXT_HIGH_MODELS=gpt-5.4
OPENAI_TEXT_FLOOR_MODELS=gpt-5.4-mini
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key
# 统一模型路由档位：
# local_free = 本地 smoke，优先 Ollama/OpenRouter free，不能作为 test_high 合格 evidence
# local_quality = 本地高质量调试，优先 OpenAI/OpenRouter 高质量层
# test_high = QA/UAT/回归，高质量层优先，禁用 free/Ollama/mock 合格证据
# prod_balanced = 生产默认，关键步骤高质量优先，其余平衡层优先
MODEL_ROUTING_PROFILE=local_free
# 兼容旧变量：未设置 MODEL_ROUTING_PROFILE 时会读取 OPENROUTER_ROUTING_PROFILE
OPENROUTER_ROUTING_PROFILE=local
# 可选：模型路由（逗号分隔）
OPENROUTER_FREE_MODELS=openrouter/free
OPENROUTER_FLOOR_MODELS=google/gemini-3-flash-preview,openai/gpt-5.4-mini,deepseek/deepseek-v3.2
OPENROUTER_HIGH_MODELS=anthropic/claude-sonnet-4.6,google/gemini-3.1-pro-preview,qwen/qwen3-max,z-ai/glm-4.6,deepseek/deepseek-v3.2
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_TEXT_MODELS=qwen3.5:9b-fast,qwen3.5:9b
MODEL_ROUTER_ENABLE_CODEX_LOCAL=0
# Codex OAuth 本机 adapter：仅供本机调试/UAT；不要读取、提交或复制 ~/.codex/auth.json
CODEX_LOCAL_ADAPTER_ENABLED=0
CODEX_LOCAL_COMMAND=codex
CODEX_LOCAL_PROFILE=quick
CODEX_LOCAL_TIMEOUT_MS=90000
CODEX_LOCAL_MAX_CONCURRENCY=1
CODEX_LOCAL_ALLOW_QUALITY_EVIDENCE=0
ASSET_SIGNING_SECRET=replace-with-short-lived-asset-secret

# baoyu-compatible runtime / image layer
BAOYU_SKILLS_DIR=vendor/baoyu-skills
BAOYU_RUNTIME_ARTIFACTS_DIR=artifacts/baoyu-runtime
BAOYU_IMAGE_PROVIDER=openrouter
OPENROUTER_IMAGE_MODEL=black-forest-labs/flux.2-pro

# 最新事实来源检索（可选；未配置时 freshness prompt 会 fail-closed，请用户粘贴来源 URL）
DRAFTORBIT_SEARCH_PROVIDER=none
TAVILY_API_KEY=
DRAFTORBIT_SEARCH_MAX_RESULTS=3

# ── Stripe（可选）─────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Starter / Growth / Max（月付 + 年付，USD）
STRIPE_STARTER_MONTHLY_PRICE_ID=
STRIPE_STARTER_YEARLY_PRICE_ID=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_YEARLY_PRICE_ID=
STRIPE_PREMIUM_MONTHLY_PRICE_ID=
STRIPE_PREMIUM_YEARLY_PRICE_ID=
# 试用天数（默认 3；上线真实扣款验收可临时设为 0）
BILLING_TRIAL_DAYS=3
# 退款演练接口（默认关闭；仅测试窗口临时开启）
BILLING_SELF_SERVICE_REFUND_ENABLED=false
# 前端是否显示“退款演练”按钮（默认关闭）
NEXT_PUBLIC_BILLING_REFUND_DRILL_ENABLED=false
# 生产默认 false；仅在自托管/应急时允许 PayPal 回退
BILLING_PAYPAL_FALLBACK_ENABLED=false

# ── PayPal（可选，订阅 Webhook）───────────────
# Sandbox: https://api-m.sandbox.paypal.com
# Live:    https://api-m.paypal.com
PAYPAL_API_BASE=https://api-m.sandbox.paypal.com
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
# 可选：用于按 plan_id 映射 DraftOrbit 套餐
PAYPAL_PLAN_ID_STARTER=
PAYPAL_PLAN_ID_PRO=
PAYPAL_PLAN_ID_PREMIUM=
